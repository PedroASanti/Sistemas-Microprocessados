DS_DQ        EQU  P3.0
DS_CLK       EQU  P3.1
DS_RST       EQU  P3.2

LCD_RS       EQU  P2.0
LCD_E        EQU  P2.1
LCD_RW       EQU  P2.2

CMD_WR_CFG   EQU  0CH       ; Write Config
CMD_START    EQU  0EEH      ; Start Convert T
CMD_RD_TEMP  EQU  0AAH      ; Read Temperature
CMD_RD_CFG   EQU  0ACH      ; Read Config

CFG_CPU_CONT EQU  02H       ; CPU=1, 1SHOT=0

TEMP_RAW_L   EQU  30H       ; bits 0-7 da temperatura lida
TEMP_RAW_H   EQU  31H       ; bit 8 (sinal)
TEMP_INT     EQU  32H       ; parte inteira (graus)
TEMP_NEG     EQU  34H       ; 0=positivo, 1=negativo

TBUF_SIGN    EQU  35H
TBUF_DIG2    EQU  36H
TBUF_DIG1    EQU  37H
TBUF_DIG0    EQU  38H

    ORG  0000H
    LJMP MAIN

    ORG  0050H

; limpa registradores/portas (evita lixo de execucao anterior)
MAIN:
    MOV  SP, #5FH
    CLR  A
    MOV  B,  #0
    MOV  R0, #0
    MOV  R1, #0
    MOV  R2, #0
    MOV  R3, #0
    MOV  R4, #0
    MOV  R5, #0
    MOV  R6, #0
    MOV  R7, #0
    CLR  C
    MOV  P0, #0FFH
    MOV  P2, #0FFH
    MOV  P3, #0FFH
    CLR  DS_RST
    CLR  DS_CLK

    LCALL LCD_INIT

    MOV  A, #80H              ; DDRAM 00H = linha 1
    LCALL LCD_CMD
    MOV  DPTR, #STR_LABEL
    LCALL LCD_PRINT_ROM

    LCALL DS1620_INIT
    LCALL DS1620_START

LOOP:
    LCALL DS1620_WAIT_DONE
    JZ   LOOP_ERRO            ; A=0 -> DONE nao pronto

    LCALL DS1620_READ_TEMP
    LCALL DECODE_TEMP
    LCALL TEMP_TO_ASCII
    LCALL LCD_ATUALIZA
    LCALL DELAY_SIM_PAUSA
    AJMP LOOP

LOOP_ERRO:
    LCALL LCD_ERRO_DONE
    LCALL DELAY_ERRO
    AJMP LOOP

; grava config (CPU=1, modo continuo); EEPROM interna, espera 10ms
DS1620_INIT:
    LCALL DS_RST_HIGH
    MOV  A, #CMD_WR_CFG
    LCALL DS_SEND_BYTE
    MOV  A, #CFG_CPU_CONT
    LCALL DS_SEND_BYTE
    LCALL DS_RST_LOW
    LCALL DELAY_10MS
    RET

; dispara conversao continua
DS1620_START:
    LCALL DS_RST_HIGH
    MOV  A, #CMD_START
    LCALL DS_SEND_BYTE
    LCALL DS_RST_LOW
    RET

; espera DONE=1 (bit 7 do config register)
DS1620_WAIT_DONE:
    LCALL DS_RST_HIGH
    MOV  A, #CMD_RD_CFG
    LCALL DS_SEND_BYTE
    LCALL DS_RECV_BYTE
    LCALL DS_RST_LOW

    ANL  A, #80H
    RET

; le os 9 bits de temperatura (8 bits + sinal)
DS1620_READ_TEMP:
    LCALL DS_RST_HIGH
    MOV  A, #CMD_RD_TEMP
    LCALL DS_SEND_BYTE

    LCALL DS_RECV_BYTE
    MOV  TEMP_RAW_L, A

    LCALL DS_RECV_BIT
    MOV  A, #0
    RLC  A
    MOV  TEMP_RAW_H, A

    LCALL DS_RST_LOW
    RET

; RST alto inicia transacao, RST baixo encerra
DS_RST_HIGH:
    CLR  DS_CLK
    SETB DS_RST
    RET

DS_RST_LOW:
    CLR  DS_RST
    RET

; envia 8 bits de A, LSB primeiro
DS_SEND_BYTE:
    MOV  R6, #8

SEND_LOOP:
    RRC  A
    MOV  DS_DQ, C
    SETB DS_CLK
    CLR  DS_CLK
    DJNZ R6, SEND_LOOP
    RET

; recebe 8 bits, LSB primeiro -> A
DS_RECV_BYTE:
    SETB DS_DQ
    MOV  A, #0
    MOV  R6, #8

RECV_LOOP:
    CLR  DS_CLK
    MOV  C, DS_DQ
    SETB DS_CLK
    RRC  A
    DJNZ R6, RECV_LOOP
    RET

; recebe 1 bit (9o bit/sinal) -> Carry
DS_RECV_BIT:
    SETB DS_DQ
    CLR  DS_CLK
    MOV  C, DS_DQ
    SETB DS_CLK
    RET

; complemento de 2 de 9 bits -> sinal + parte inteira (sem fracao)
DECODE_TEMP:
    MOV  A, TEMP_RAW_H
    ANL  A, #1
    MOV  TEMP_NEG, A
    JZ   EXT_POS
    MOV  A, #0FFH
    SJMP EXT_FIM
EXT_POS:
    MOV  A, #00H
EXT_FIM:
    MOV  TEMP_RAW_H, A

    MOV  A, TEMP_RAW_H
    RRC  A
    MOV  A, TEMP_RAW_L
    RRC  A
    MOV  TEMP_INT, A

    MOV  A, TEMP_NEG
    JZ   DECODE_FIM
    MOV  A, TEMP_INT
    CPL  A
    ADD  A, #1
    MOV  TEMP_INT, A

DECODE_FIM:
    RET

; TEMP_INT -> digitos ASCII (subtracao reiterada)
TEMP_TO_ASCII:
    MOV  A, TEMP_NEG
    JZ   ASCII_POS
    MOV  TBUF_SIGN, #'-'
    SJMP ASCII_SINAL_FIM
ASCII_POS:
    MOV  TBUF_SIGN, #' '
ASCII_SINAL_FIM:

    MOV  R0, TEMP_INT
    MOV  R3, #0
DIG_C:
    MOV  A, R0
    CLR  C
    SUBB A, #100
    JC   FIM_DIG_C
    MOV  R0, A
    INC  R3
    AJMP DIG_C
FIM_DIG_C:
    MOV  A, R3
    ADD  A, #30H
    MOV  TBUF_DIG2, A

    MOV  R3, #0
DIG_D:
    MOV  A, R0
    CLR  C
    SUBB A, #10
    JC   FIM_DIG_D
    MOV  R0, A
    INC  R3
    AJMP DIG_D
FIM_DIG_D:
    MOV  A, R3
    ADD  A, #30H
    MOV  TBUF_DIG1, A

    MOV  A, R0
    ADD  A, #30H
    MOV  TBUF_DIG0, A
    RET

; escreve sinal + 3 digitos + grau + C na linha 2
LCD_ATUALIZA:
    MOV  A, #0C0H              ; DDRAM 40H = linha 2
    LCALL LCD_CMD

    MOV  A, TBUF_SIGN
    LCALL LCD_DATA
    MOV  A, TBUF_DIG2
    LCALL LCD_DATA
    MOV  A, TBUF_DIG1
    LCALL LCD_DATA
    MOV  A, TBUF_DIG0
    LCALL LCD_DATA

    MOV  A, #0DFH              ; simbolo de grau (CGROM)
    LCALL LCD_DATA
    MOV  A, #'C'
    LCALL LCD_DATA
    RET

; escreve "ERRO DONE" na linha 2, quando DONE=0
LCD_ERRO_DONE:
    MOV  A, #0C0H              ; DDRAM 40H = linha 2
    LCALL LCD_CMD
    MOV  DPTR, #STR_ERRO_DONE
    LCALL LCD_PRINT_ROM
    RET

; inicializacao LCD 8 bits (datasheet HD44780)
LCD_INIT:
    CLR  LCD_RW
    CLR  LCD_RS
    CLR  LCD_E
    LCALL DELAY_15MS

    MOV  P0, #30H
    SETB LCD_E
    CLR  LCD_E
    LCALL DELAY_4100US

    MOV  P0, #30H
    SETB LCD_E
    CLR  LCD_E
    LCALL DELAY_100US

    MOV  P0, #30H
    SETB LCD_E
    CLR  LCD_E
    LCALL DELAY_100US

    MOV  A, #38H              ; 8 bits, 2 linhas, fonte 5x8
    LCALL LCD_CMD
    MOV  A, #08H              ; Display OFF
    LCALL LCD_CMD
    MOV  A, #01H              ; Clear Display
    LCALL LCD_CMD
    LCALL DELAY_1520US
    MOV  A, #06H              ; Entry Mode: incrementa cursor
    LCALL LCD_CMD
    MOV  A, #0CH              ; Display ON, cursor OFF
    LCALL LCD_CMD
    RET

; envia comando (RS=0) ou dado (RS=1) via P0, pulsando E
LCD_CMD:
    CLR  LCD_RS
    MOV  P0, A
    SETB LCD_E
    CLR  LCD_E
    LCALL DELAY_37US
    RET

LCD_DATA:
    SETB LCD_RS
    MOV  P0, A
    SETB LCD_E
    CLR  LCD_E
    LCALL DELAY_37US
    RET

; imprime string terminada em 00H (CODE memory, DPTR)
LCD_PRINT_ROM:
    CLR  A
    MOVC A, @A+DPTR
    JZ   PRINT_FIM
    LCALL LCD_DATA
    INC  DPTR
    AJMP LCD_PRINT_ROM
PRINT_FIM:
    RET

DELAY_37US:
    MOV  R7, #18
    DJNZ R7, $
    RET

DELAY_100US:
    MOV  R7, #49
    DJNZ R7, $
    RET

DELAY_1520US:
    MOV  R6, #15
D1520_LP:
    MOV  R7, #51
    DJNZ R7, $
    DJNZ R6, D1520_LP
    RET

DELAY_4100US:
    MOV  R6, #41
D4100_LP:
    MOV  R7, #50
    DJNZ R7, $
    DJNZ R6, D4100_LP
    RET

DELAY_10MS:
    MOV  R5, #2
D10_A:
    MOV  R6, #25
D10_B:
    MOV  R7, #100
    DJNZ R7, $
    DJNZ R6, D10_B
    DJNZ R5, D10_A
    RET

DELAY_15MS:
    MOV  R5, #3
D15_A:
    MOV  R6, #25
D15_B:
    MOV  R7, #100
    DJNZ R7, $
    DJNZ R6, D15_B
    DJNZ R5, D15_A
    RET

; delays calculados p/ hardware real (12MHz); trocar DELAY_SIM_PAUSA por
; DELAY_500MS e usar polling com DELAY_DONE_POLL se for fora do simulador
DELAY_900MS:
    MOV  R4, #18
D900_A:
    MOV  R5, #10
D900_B:
    MOV  R6, #25
D900_C:
    MOV  R7, #100
    DJNZ R7, $
    DJNZ R6, D900_C
    DJNZ R5, D900_B
    DJNZ R4, D900_A
    RET

DELAY_500MS:
    MOV  R4, #10
D500_A:
    MOV  R5, #10
D500_B:
    MOV  R6, #25
D500_C:
    MOV  R7, #100
    DJNZ R7, $
    DJNZ R6, D500_C
    DJNZ R5, D500_B
    DJNZ R4, D500_A
    RET

DELAY_ERRO:
    MOV  R5, #3
DSIMP_A:
    MOV  R6, #25
DSIMP_B:
    MOV  R7, #93
    DJNZ R7, $
    DJNZ R6, DSIMP_B
    DJNZ R5, DSIMP_A
    RET

STR_LABEL:
    DB  'T', 'E', 'M', 'P', 'E', 'R', 'A', 'T', 'U', 'R', 'A', ':', 00H

STR_ERRO_DONE:
    DB  'E', 'R', 'R', 'O', ' ', 'D', 'O', 'N', 'E', ' ', ' ', 00H

    END
